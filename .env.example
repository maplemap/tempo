# Login password
ADMIN_PASSWORD=change-me
# Random string for JWT signing (e.g. openssl rand -hex 32)
JWT_SECRET=change-me-to-a-long-random-string
# Server port
PORT=3000
# SQLite data directory (mounted as Docker volume)
DATA_DIR=./data
# Set to true only if serving over HTTPS
SECURE_COOKIE=false
# GitHub PAT with repo scope — enables PR/review/merge sync
GITHUB_TOKEN=
# Branch that counts as "shipped"
GITHUB_BASE_BRANCH=main
# How often to sync GitHub (minutes)
SYNC_INTERVAL_MINUTES=15
# How many days back to fetch on first sync
BACKFILL_DAYS=30
